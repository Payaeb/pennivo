# Use a flat (hoisted) node_modules layout instead of pnpm's strict
# symlinked layout. Required by electron-builder, which can't trace
# transitive dependencies through deeply-nested pnpm symlinks (e.g.
# `electron-updater -> builder-util-runtime -> debug -> ms`) and
# silently drops them from the packed asar.
#
# Symptom of removing this: installed app crashes on launch with
# "Cannot find module 'ms'" because debug/src/common.js requires
# ms but the asar packer never copied it.
node-linker=hoisted
