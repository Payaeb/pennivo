{
  "name": "pennivo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A modern markdown editor with WYSIWYG and source mode",
  "author": "Paya Ebrahimi <payaeb@gmail.com>",
  "license": "MIT",
  "homepage": "https://www.pennivo.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Payaeb/pennivo.git"
  },
  "bugs": {
    "url": "https://github.com/Payaeb/pennivo/issues"
  },
  "scripts": {
    "dev": "pnpm --filter @pennivo/desktop dev",
    "build": "pnpm --filter @pennivo/core build && pnpm --filter @pennivo/desktop build",
    "lint": "eslint packages/core/src packages/ui/src packages/desktop/src",
    "lint:fix": "eslint packages/core/src packages/ui/src packages/desktop/src --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,css}\"",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "preflight": "pnpm install --frozen-lockfile && pnpm typecheck && pnpm test && pnpm lint && pnpm format:check && pnpm build",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.2",
    "sharp": "^0.34.5",
    "typescript-eslint": "^8.58.1"
  }
}
