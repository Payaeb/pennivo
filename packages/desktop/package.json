{
  "name": "@pennivo/desktop",
  "version": "1.0.0",
  "private": true,
  "productName": "Pennivo",
  "description": "A modern markdown editor with WYSIWYG and source mode",
  "author": "Paya Ebrahimi <payaeb@gmail.com>",
  "license": "MIT",
  "homepage": "https://www.pennivo.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Payaeb/pennivo.git",
    "directory": "packages/desktop"
  },
  "bugs": {
    "url": "https://github.com/Payaeb/pennivo/issues"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE vite",
    "build": "tsc && vite build",
    "build:icon": "node scripts/build-icon.mjs",
    "build:file-icon": "node scripts/build-file-icon.mjs",
    "dist": "electron-builder --win --publish never",
    "dist:dir": "electron-builder --dir --win --publish never",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "clean": "rm -rf dist release"
  },
  "build": {
    "appId": "com.pennivo.app",
    "productName": "Pennivo",
    "copyright": "Copyright © 2026 Paya Ebrahimi",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/icon.png",
      "resources/icon.ico",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Pennivo-Setup-${version}.exe",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "description": "Markdown Document",
          "icon": "build/file-icon.ico",
          "role": "Editor"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pennivo",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": null
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Payaeb",
        "repo": "pennivo"
      }
    ]
  },
  "dependencies": {
    "@pennivo/core": "workspace:*",
    "@pennivo/ui": "workspace:*",
    "electron-updater": "^6.8.3",
    "ms": "^2.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "35.7.5",
    "electron-builder": "^26.8.1",
    "png2icons": "^2.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}